            <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 20 }}>
              <SectionHeader title="Mapa de Calor — Carga Semanal" icon="🌡️"/>
              <WeekHeatmap data={DATA}/>
            </div>
          </>
        )}

        {/* ── GANTT ── */}
        {tab === "gantt" && (
          <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 24 }}>
            <SectionHeader title={`Cronograma Gantt — 52 Semanas 2026 (Actual: S${CURRENT_WEEK})`} icon="📅"/>
            <div style={{ display: "flex", gap: 12, marginBottom: 16, flexWrap: "wrap" }}>
              <select value={filterAud} onChange={e => setFilterAud(e.target.value)} style={{
                background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.1)",
                color: "#CBD5E1", borderRadius: 8, padding: "6px 12px", fontSize: 12
              }}>
                <option value="TODOS">Todos los auditores</option>
                {[...new Set(DATA.map(d => d.auditor))].sort().map(a => <option key={a} value={a}>{a}</option>)}
              </select>
              <select value={filterTipo} onChange={e => setFilterTipo(e.target.value)} style={{
                background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.1)",
                color: "#CBD5E1", borderRadius: 8, padding: "6px 12px", fontSize: 12
              }}>
                <option value="TODOS">Todos los tipos</option>
                {[...new Set(DATA.map(d => d.tipo))].map(t => <option key={t} value={t}>{t}</option>)}
              </select>
            </div>
            <GanttChart data={filteredData} onSelect={setSelected}/>
            <div style={{ marginTop: 16, color: "#475569", fontSize: 11 }}>
              Haz clic en cualquier barra para ver el detalle del acto de fiscalización. Las barras con borde blanco están actualmente en ejecución.
            </div>
          </div>
        )}

        {/* ── RIESGO ── */}
        {tab === "riesgo" && (
          <div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 16, marginBottom: 20 }}>
              {[
                { label: "Alto Riesgo (≥60)", count: DATA.filter(d=>riskScore(d)>=60).length, color: "#EF4444", desc: "Requieren atención inmediata" },
                { label: "Riesgo Medio (35-59)", count: DATA.filter(d=>riskScore(d)>=35&&riskScore(d)<60).length, color: "#F59E0B", desc: "Monitoreo cercano" },
                { label: "Bajo Riesgo (<35)", count: DATA.filter(d=>riskScore(d)<35).length, color: "#10B981", desc: "Ejecución normal" },
              ].map(r => (
                <div key={r.label} style={{
                  background: `${r.color}10`, border: `1px solid ${r.color}30`,
                  borderRadius: 12, padding: "20px 24px"
                }}>
                  <div style={{ color: r.color, fontSize: 36, fontWeight: 900, fontFamily: "monospace" }}>{r.count}</div>
                  <div style={{ color: "#CBD5E1", fontSize: 13, fontWeight: 700, marginTop: 4 }}>{r.label}</div>
                  <div style={{ color: "#64748B", fontSize: 11, marginTop: 2 }}>{r.desc}</div>
                </div>
              ))}
            </div>
            <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 24 }}>
              <SectionHeader title="Matriz de Riesgo Completa — Todos los Actos" icon="⚠️"/>
              <div style={{ marginBottom: 12, color: "#475569", fontSize: 11 }}>
                El índice integra: proximidad de vencimiento · duración · tamaño del universo · existencia de auditoría precedente · tipo de acto. Clic en cada elemento para detalles.
              </div>
              <RiskMatrix data={DATA} onSelect={setSelected}/>
            </div>
          </div>
        )}

        {/* ── CARGA ── */}
        {tab === "carga" && (
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
            <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 24 }}>
              <SectionHeader title="Carga de Trabajo por Auditor" icon="👥"/>
              <WorkloadChart data={DATA}/>
            </div>
            <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 24 }}>
              <SectionHeader title="Auditorías por Institución" icon="🏛️"/>
              <InstChart data={DATA}/>
            </div>
          </div>
        )}

        {/* ── FINANCIERO ── */}
        {tab === "financiero" && (
          <div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20, marginBottom: 20 }}>
              <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 24 }}>
                <SectionHeader title="Universo por Institución" icon="🏛️"/>
                <FinanceBar data={DATA}/>
              </div>
              <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 24 }}>
                <SectionHeader title="Distribución por Tipo de Acto" icon="📊"/>
                {Object.entries(TIPO_COLOR).map(([tipo, color]) => {
                  const u = DATA.filter(d=>d.tipo===tipo).reduce((s,d)=>s+(d.universo||0),0);
                  const cnt = DATA.filter(d=>d.tipo===tipo).length;
                  return (
                    <div key={tipo} style={{ marginBottom: 14 }}>
                      <div style={{ display:"flex", justifyContent:"space-between", marginBottom:4 }}>
                        <span style={{color:"#CBD5E1",fontSize:12}}>{tipo}</span>
                        <div style={{display:"flex",gap:12}}>
                          <span style={{color:"#64748B",fontSize:11}}>{cnt} actos</span>
                          <span style={{color,fontSize:12,fontWeight:700,fontFamily:"monospace"}}>{fmtM(u||null)}</span>
                        </div>
                      </div>
                      <div style={{height:14,background:"rgba(255,255,255,0.04)",borderRadius:4}}>
                        <div style={{height:"100%",width:`${cnt/DATA.length*100}%`,background:`${color}aa`,borderRadius:4}}/>
                      </div>
                    </div>
                  );
                })}
                <div style={{marginTop:16,padding:16,background:"rgba(255,255,255,0.03)",borderRadius:10}}>
                  <div style={{color:"#475569",fontSize:11,marginBottom:4}}>UNIVERSO TOTAL FISCALIZADO</div>
                  <div style={{color:"#F1F5F9",fontSize:28,fontWeight:900,fontFamily:"monospace"}}>{fmt(totalUniverso)}</div>
                  <div style={{color:"#64748B",fontSize:11,marginTop:4}}>Recursos públicos bajo revisión PAF 2026</div>
                </div>
              </div>
            </div>
            {/* Top 5 por monto */}
            <div style={{ background: "rgba(255,255,255,0.03)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 14, padding: 24 }}>
              <SectionHeader title="Top 10 — Auditorías por Monto de Universo" icon="🏆"/>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
                {[...DATA].filter(d=>d.universo).sort((a,b)=>b.universo-a.universo).slice(0,10).map((a, i) => (
                  <div key={a.id} onClick={() => setSelected(a)} style={{
                    background:"rgba(255,255,255,0.03)", border:"1px solid rgba(255,255,255,0.06)",
                    borderRadius:8, padding:"12px 14px", cursor:"pointer",
                    display:"flex", gap:12, alignItems:"center"
                  }}>
                    <div style={{
                      width:28, height:28, borderRadius:8, flexShrink:0,
                      background: i < 3 ? ["linear-gradient(135deg,#F59E0B,#D97706)","linear-gradient(135deg,#94A3B8,#64748B)","linear-gradient(135deg,#C2855A,#92522A)"][i] : "rgba(255,255,255,0.06)",
                      display:"flex", alignItems:"center", justifyContent:"center",
                      color:"#0F172A", fontWeight:900, fontSize:12
                    }}>{i+1}</div>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{color:"#CBD5E1",fontSize:11,fontWeight:600,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{a.instShort}</div>
                      <div style={{color:"#475569",fontSize:10}}>{a.tipo.split(" ").slice(0,2).join(" ")}</div>
                    </div>
                    <div style={{color:a.tipoColor,fontWeight:800,fontSize:12,fontFamily:"monospace",flexShrink:0}}>{fmtM(a.universo)}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* ── CATÁLOGO ── */}
        {tab === "catalogo" && (
          <div>
            <div style={{ display:"flex", gap:12, marginBottom:16, flexWrap:"wrap" }}>
              <input
                value={search} onChange={e => setSearch(e.target.value)}
                placeholder="Buscar institución, número, auditor..."
                style={{
                  background:"rgba(255,255,255,0.06)", border:"1px solid rgba(255,255,255,0.1)",
                  color:"#CBD5E1", borderRadius:8, padding:"8px 14px", fontSize:12,
                  minWidth:280, outline:"none"
                }}
              />
              <select value={filterAud} onChange={e => setFilterAud(e.target.value)} style={{
                background:"rgba(255,255,255,0.06)", border:"1px solid rgba(255,255,255,0.1)",
                color:"#CBD5E1", borderRadius:8, padding:"8px 12px", fontSize:12
              }}>
                <option value="TODOS">Todos los auditores</option>
                {[...new Set(DATA.map(d => d.auditor))].sort().map(a => <option key={a} value={a}>{a}</option>)}
              </select>
              <select value={filterTipo} onChange={e => setFilterTipo(e.target.value)} style={{
                background:"rgba(255,255,255,0.06)", border:"1px solid rgba(255,255,255,0.1)",
                color:"#CBD5E1", borderRadius:8, padding:"8px 12px", fontSize:12
              }}>
                <option value="TODOS">Todos los tipos</option>
                {[...new Set(DATA.map(d => d.tipo))].map(t => <option key={t} value={t}>{t}</option>)}
              </select>
              <div style={{
                background:"rgba(255,255,255,0.04)", borderRadius:8, padding:"8px 14px",
                color:"#64748B", fontSize:12
              }}>
                {filteredData.length} de {DATA.length} actos
              </div>
            </div>

            <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
              {filteredData.map(a => {
                const r = riskLabel(a.risk);
                const status = a.completed ? { label:"CONCLUIDO", color:"#6366F1" } :
                               a.inProgress ? { label:"EN EJECUCIÓN", color:"#10B981" } :
                               { label:"PENDIENTE", color:"#F59E0B" };
                return (
                  <div key={a.id} onClick={() => setSelected(a)} style={{
                    background:"rgba(255,255,255,0.03)", border:"1px solid rgba(255,255,255,0.06)",
                    borderRadius:10, padding:"14px 18px", cursor:"pointer",
                    display:"grid", gridTemplateColumns:"1fr 140px 100px 80px 80px",
                    gap:12, alignItems:"center",
                    transition:"background 0.15s"
                  }}>
                    <div style={{minWidth:0}}>
                      <div style={{
                        display:"inline-block", background:`${a.tipoColor}18`,
                        color:a.tipoColor, fontSize:9, fontWeight:700, padding:"2px 8px",
                        borderRadius:10, marginBottom:4
                      }}>{a.tipo.split(" ").slice(0,3).join(" ")}</div>
                      <div style={{color:"#F1F5F9",fontSize:13,fontWeight:700,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{a.inst}</div>
                      <div style={{color:"#475569",fontSize:10,fontFamily:"monospace",marginTop:2}}>{a.num}</div>
                    </div>
                    <div style={{textAlign:"center"}}>
                      <div style={{color:"#94A3B8",fontSize:11,marginBottom:2}}>Ejecución</div>
                      <div style={{color:"#CBD5E1",fontSize:11,fontWeight:600}}>S{a.sem_ini}–S{a.sem_fin}</div>
                      <div style={{color:"#475569",fontSize:10}}>({a.semanas} sem)</div>
                    </div>
                    <div style={{textAlign:"center"}}>
                      <div style={{color:status.color,fontSize:10,fontWeight:700,letterSpacing:"0.06em"}}>{status.label}</div>
                      <div style={{color:"#475569",fontSize:9,marginTop:2}}>{a.auditor}</div>
                    </div>
                    <div style={{textAlign:"center"}}>
                      <div style={{color:r.color,fontSize:11,fontWeight:800}}>{r.label}</div>
                      <div style={{color:"#475569",fontSize:10}}>{a.risk}/100</div>
                    </div>
                    <div style={{textAlign:"right"}}>
                      <div style={{color:"#CBD5E1",fontSize:11,fontWeight:700}}>{fmtM(a.universo)}</div>
                      <div style={{color:"#475569",fontSize:9}}>{a.daysLeft < 0 ? "Vencida" : `${a.daysLeft}d`}</div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>

      {/* DETAIL PANEL */}
      {selected && <DetailPanel audit={selected} onClose={() => setSelected(null)}/>}
    </div>
  );
}
