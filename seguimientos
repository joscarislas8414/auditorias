// ── Helpers ──────────────────────────────────────────────────────────────────
const fmt = (n) => n == null ? "—" : new Intl.NumberFormat("es-MX",{style:"currency",currency:"MXN",maximumFractionDigits:0}).format(n);
const fmtM = (n) => n == null ? "—" : `$${(n/1e6).toFixed(1)}M`;
const daysLeft = (d) => Math.ceil((new Date(d) - TODAY) / 86400000);

function riskScore(a) {
  let s = 0;
  const dl = daysLeft(a.fin_eje);
  if (dl < 0) s += 40;
  else if (dl < 30) s += 25;
  else if (dl < 60) s += 10;
  if (a.semanas > 25) s += 20;
  else if (a.semanas > 16) s += 10;
  if (a.universo > 5e9) s += 20;
  else if (a.universo > 1e9) s += 10;
  if (!a.precedente) s += 10;
  if (a.tipo === "Auditorías de Cumplimiento") s += 5;
  return Math.min(s, 100);
}

function riskLabel(s) {
  if (s >= 60) return { label: "ALTO", color: "#EF4444" };
  if (s >= 35) return { label: "MEDIO", color: "#F59E0B" };
  return { label: "BAJO", color: "#10B981" };
}

