// ── HEAT MAP ─────────────────────────────────────────────────────────────────
function WeekHeatmap({ data }) {
  const weeks = Array.from({ length: 52 }, (_, i) => i + 1);
  const counts = weeks.map(w => data.filter(d => w >= d.sem_ini && w <= d.sem_fin).length);
  const maxC = Math.max(...counts);

  const monthLabels = [
    { w: 1, label: "Ene" }, { w: 5, label: "Feb" }, { w: 9, label: "Mar" },
    { w: 14, label: "Abr" }, { w: 18, label: "May" }, { w: 22, label: "Jun" },
    { w: 27, label: "Jul" }, { w: 31, label: "Ago" }, { w: 36, label: "Sep" },
    { w: 40, label: "Oct" }, { w: 44, label: "Nov" }, { w: 48, label: "Dic" },
  ];

  return (
    <div>
      <div style={{ position: "relative", marginBottom: 2 }}>
        {monthLabels.map(m => (
          <span key={m.label} style={{
            position: "absolute", left: `${(m.w - 1) / 52 * 100}%`,
            color: "#475569", fontSize: 9, fontWeight: 600
          }}>{m.label}</span>
        ))}
        <div style={{ height: 14 }}/>
      </div>
      <div style={{ display: "flex", gap: 2, flexWrap: "wrap" }}>
        {weeks.map(w => {
          const c = counts[w - 1];
          const intensity = c / maxC;
          const isCurrent = w === CURRENT_WEEK;
          return (
            <div
              key={w}
              title={`Semana ${w}: ${c} auditorías activas`}
              style={{
                width: `calc(${100 / 52}% - 2px)`, minWidth: 10,
                height: 28, borderRadius: 3,
                background: c === 0 ? "rgba(255,255,255,0.04)" :
                  `rgba(59, 130, 246, ${0.15 + intensity * 0.75})`,
                border: isCurrent ? "2px solid #F59E0B" : "1px solid transparent",
                display: "flex", alignItems: "center", justifyContent: "center",
                cursor: "default"
              }}
            >
              <span style={{ color: "rgba(255,255,255,0.6)", fontSize: 8, fontWeight: 700 }}>
                {c || ""}
              </span>
            </div>
          );
        })}
      </div>
      <div style={{ display: "flex", alignItems: "center", gap: 8, marginTop: 8, justifyContent: "flex-end" }}>
        <span style={{ color: "#475569", fontSize: 10 }}>Menos</span>
        {[0, 0.2, 0.4, 0.65, 0.9].map((v, i) => (
          <div key={i} style={{ width: 14, height: 14, borderRadius: 3, background: v === 0 ? "rgba(255,255,255,0.04)" : `rgba(59,130,246,${0.15+v*0.75})` }}/>
        ))}
        <span style={{ color: "#475569", fontSize: 10 }}>Más carga</span>
      </div>
    </div>
  );
}

