// ── GANTT ────────────────────────────────────────────────────────────────────
function GanttChart({ data, onSelect }) {
  const TOTAL_WEEKS = 52;
  const COL_W = 14;
  const ROW_H = 26;
  const LABEL_W = 56;

  const auditores = [...new Set(data.map(d => d.auditor))].sort();

  return (
    <div style={{ overflowX: "auto", overflowY: "auto", maxHeight: 520 }}>
      <div style={{ minWidth: LABEL_W + TOTAL_WEEKS * COL_W + 20 }}>
        {/* Month labels */}
        <div style={{ display: "flex", marginLeft: LABEL_W, marginBottom: 2 }}>
          {["Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"].map((m, i) => (
            <div key={m} style={{
              width: (i === 0 ? 3 : i <= 1 ? 4 : i <= 2 ? 4 : 4) * COL_W,
              width: Math.round(TOTAL_WEEKS / 12) * COL_W,
              color: "#475569", fontSize: 10, fontWeight: 600, letterSpacing: "0.05em",
              flexShrink: 0, textAlign: "center"
            }}>{m}</div>
          ))}
        </div>
        {/* Week numbers */}
        <div style={{ display: "flex", marginLeft: LABEL_W, marginBottom: 6 }}>
          {Array.from({ length: TOTAL_WEEKS }, (_, i) => i + 1).map(w => (
            <div key={w} style={{
              width: COL_W, flexShrink: 0, textAlign: "center",
              color: w === CURRENT_WEEK ? "#F59E0B" : "#334155",
              fontSize: 8, fontWeight: w === CURRENT_WEEK ? 800 : 400,
            }}>{w % 4 === 0 ? w : ""}</div>
          ))}
        </div>

        {auditores.map(aud => {
          const audData = data.filter(d => d.auditor === aud);
          return (
            <div key={aud}>
              <div style={{ display: "flex", alignItems: "center", marginBottom: 2 }}>
                <div style={{
                  width: LABEL_W, color: "#F59E0B", fontSize: 10, fontWeight: 700,
                  letterSpacing: "0.05em", flexShrink: 0, paddingRight: 8, textAlign: "right"
                }}>{aud}</div>
                <div style={{ display: "flex", position: "relative", height: ROW_H }}>
                  {/* Grid background */}
                  {Array.from({ length: TOTAL_WEEKS }, (_, i) => (
                    <div key={i} style={{
                      width: COL_W, flexShrink: 0, height: ROW_H,
                      background: (i + 1) === CURRENT_WEEK ? "rgba(245,158,11,0.06)" :
                                  i % 2 === 0 ? "rgba(255,255,255,0.015)" : "transparent",
                      borderRight: "1px solid rgba(255,255,255,0.03)"
                    }}/>
                  ))}
                  {/* Audit bars */}
                  {audData.map(a => (
                    <div
                      key={a.id}
                      onClick={() => onSelect(a)}
                      title={`${a.num}\n${a.inst}\nSem ${a.sem_ini}–${a.sem_fin}`}
                      style={{
                        position: "absolute",
                        left: (a.sem_ini - 1) * COL_W,
                        width: (a.sem_fin - a.sem_ini + 1) * COL_W - 2,
                        height: ROW_H - 8, top: 4,
                        background: a.completed ? "#1E293B" : a.tipoColor,
                        opacity: a.completed ? 0.5 : 1,
                        borderRadius: 4,
                        cursor: "pointer",
                        border: a.inProgress ? `2px solid white` : "none",
                        boxShadow: a.inProgress ? `0 0 8px ${a.tipoColor}60` : "none",
                        transition: "opacity 0.15s",
                        display: "flex", alignItems: "center",
                        paddingLeft: 4, overflow: "hidden",
                      }}
                    >
                      <span style={{ color: "#0F172A", fontSize: 9, fontWeight: 700, whiteSpace: "nowrap", overflow: "hidden" }}>
                        {a.instShort}
                      </span>
                    </div>
                  ))}
                  {/* Current week line */}
                  <div style={{
                    position: "absolute",
                    left: (CURRENT_WEEK - 1) * COL_W,
                    width: 2, height: ROW_H,
                    background: "#F59E0B", opacity: 0.8, zIndex: 10
                  }}/>
                </div>
              </div>
            </div>
          );
        })}

        {/* Legend */}
        <div style={{ display: "flex", gap: 16, marginLeft: LABEL_W, marginTop: 12, flexWrap: "wrap" }}>
          {Object.entries(TIPO_COLOR).map(([t, c]) => (
            <div key={t} style={{ display: "flex", alignItems: "center", gap: 5 }}>
              <div style={{ width: 12, height: 8, background: c, borderRadius: 2 }}/>
