// ── FINANCE TREEMAP ──────────────────────────────────────────────────────────
function FinanceBar({ data }) {
  const byInst = Object.entries(INST_SHORT).map(([inst, short]) => {
    const instData = data.filter(d => d.inst === inst);
    const u = instData.reduce((s, d) => s + (d.universo || 0), 0);
    return { short, universo: u, count: instData.length };
  }).filter(d => d.universo > 0).sort((a, b) => b.universo - a.universo);

  const maxU = byInst[0]?.universo || 1;

  const COLORS = ["#3B82F6","#8B5CF6","#10B981","#F59E0B","#EC4899","#EF4444","#06B6D4","#84CC16"];

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
      {byInst.map((d, i) => (
        <div key={d.short}>
          <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 4 }}>
            <span style={{ color: "#CBD5E1", fontSize: 12, fontWeight: 600 }}>{d.short}</span>
            <span style={{ color: COLORS[i], fontSize: 12, fontWeight: 800, fontFamily: "monospace" }}>{fmtM(d.universo)}</span>
          </div>
          <div style={{ height: 20, background: "rgba(255,255,255,0.04)", borderRadius: 4 }}>
            <div style={{
              height: "100%", width: `${(d.universo / maxU) * 100}%`,
              background: `linear-gradient(90deg, ${COLORS[i]}60, ${COLORS[i]})`,
              borderRadius: 4
            }}/>
          </div>
        </div>
      ))}
    </div>
  );
}

